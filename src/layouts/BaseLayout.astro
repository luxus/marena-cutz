---
import '../styles/global.css';
import { getEntry } from 'astro:content';

const settingsEntry = await getEntry('settings', 'settings');
const s = settingsEntry!.data;

const { title = s.name } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta
      name="description"
      content={s.metaDescription ||
        `${s.name} ${s.tagline} in Bülach. Clean cuts, sharp fades und präzise Schnitte.`}
    />
    <meta name="theme-color" content="#131313" />

    <!-- Open Graph / Social -->
    <meta property="og:title" content={`${s.name} | ${s.tagline} in Bülach`} />
    <meta
      property="og:description"
      content={s.ogDescription || 'Präzise Schnitte. Klare Linien. Dein Style. Unser Fokus.'}
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://marenacutz.ch" />
    <meta property="og:locale" content="de_CH" />
    <meta property="og:image" content="/images/salon-hero-new.png" />
    <meta property="og:image:alt" content={s.ogImageAlt || `${s.name} barber shop in Bülach`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${s.name} | ${s.tagline}`} />
    <meta
      name="twitter:description"
      content={s.twitterDescription || 'Clean Cuts. Sharp Fades. Präzise Schnitte in Bülach.'}
    />
    <meta name="twitter:image" content="/images/salon-hero-new.png" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Theme initialization (prevents flash).
         Priority: URL params (testing/sharing) > localStorage > defaults.
         The allowlist arrays below MUST stay in sync with src/lib/themes.ts VALID_THEMES / VALID_MODES
         (is:inline scripts cannot import ES modules). Add a theme: update themes.ts, this script, and global.css. -->
    <script is:inline>
      (function () {
        try {
          const params = new URLSearchParams(window.location.search);
          let theme = params.get('theme');
          let mode = params.get('mode');

          // Keep in sync with src/lib/themes.ts (see export comment there). Duplication is unavoidable for is:inline.
          const validThemes = ['architectural'];
          const validModes = ['light', 'dark', 'system'];

          if (!theme || !validThemes.includes(theme)) {
            theme = localStorage.getItem('theme');
          }
          if (!mode || !validModes.includes(mode)) {
            mode = localStorage.getItem('mode');
          }

          if (!theme) theme = 'architectural';
          if (!mode) mode = 'dark';
          // Resolve 'system' to actual OS preference at paint time
          if (mode === 'system') {
            mode = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }

          // Persist chosen values so they survive when URL params are removed
          localStorage.setItem('theme', theme);
          localStorage.setItem('mode', mode);

          document.documentElement.dataset.theme = theme;
          document.documentElement.dataset.mode = mode;

          // Mark that JS is active early — used by any progressive enhancement (reveals, etc.)
          // This runs before body paint so first paint is always fully styled.
          document.documentElement.classList.add('js');
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <slot />

    <!-- Scroll-reveal: extracted to src/lib/scroll-reveal.ts, run after first paint -->
    <script>
      import { initScrollReveals } from '../lib/scroll-reveal';

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          requestAnimationFrame(() => requestAnimationFrame(initScrollReveals));
        });
      } else {
        requestAnimationFrame(() => requestAnimationFrame(initScrollReveals));
      }
    </script>
  </body>
</html>
