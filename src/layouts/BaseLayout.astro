---
import '../styles/global.css';
import { frontmatter as s } from '../content/settings.md';
const { title = s.name } = Astro.props;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={s.metaDescription || `${s.name} ${s.tagline} in Bülach. Clean cuts, sharp fades und präzise Schnitte.`} />
    <meta name="theme-color" content="#131313" />

    <!-- Open Graph / Social -->
    <meta property="og:title" content={`${s.name} | ${s.tagline} in Bülach`} />
    <meta property="og:description" content={s.ogDescription || 'Präzise Schnitte. Klare Linien. Dein Style. Unser Fokus.'} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://marenacutz.ch" />
    <meta property="og:locale" content="de_CH" />
    <meta property="og:image" content="/images/salon-hero-new.png" />
    <meta property="og:image:alt" content={s.ogImageAlt || `${s.name} barber shop in Bülach`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${s.name} | ${s.tagline}`} />
    <meta name="twitter:description" content={s.twitterDescription || 'Clean Cuts. Sharp Fades. Präzise Schnitte in Bülach.'} />
    <meta name="twitter:image" content="/images/salon-hero-new.png" />

    <!-- Modern favicon setup (SVG first for best quality) -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Theme initialization (prevents flash). 
         Priority: URL params (for testing/sharing) > readable cookies (set by /api/preferences for server session + survive localStorage clear) > localStorage > system pref.
         The Cloudflare KV SESSION (via adapter + our API) is the durable cross-device source of truth for future SSR pages.
         This script is the only remaining is:inline; everything else is now proper Svelte 5 runes + actions.

         Cookie parsing is now robust (Issue 2): splits on first '=', per-value decode with try/catch fallback to raw value,
         never throws on malformed % sequences from other cookies. Called once.
         The allowlist arrays below MUST be kept manually in sync with src/lib/themes.ts:VALID_THEMES / VALID_MODES
         (the is:inline script cannot import ES modules). -->
    <script is:inline>
      (function() {
        try {
          const params = new URLSearchParams(window.location.search);
          let theme = params.get('theme');
          let mode = params.get('mode');

          // Keep in sync with src/lib/themes.ts (see export comment there). Duplication is unavoidable for is:inline.
          const validThemes = ['architectural', 'brutalist', 'warm', 'cool'];
          const validModes = ['light', 'dark'];

          // Robust cookie parser (never throws on bad % or unusual cookies)
          function parseCookies() {
            const out = Object.create(null);
            const raw = document.cookie || '';
            if (!raw) return out;
            raw.split(';').forEach((pair) => {
              const eq = pair.indexOf('=');
              if (eq === -1) return;
              const k = pair.slice(0, eq).trim();
              let v = pair.slice(eq + 1).trim();
              if (!k) return;
              try {
                v = decodeURIComponent(v);
              } catch {
                // leave raw value for cookies with literal % not part of a valid sequence
              }
              out[k] = v;
            });
            return out;
          }

          // URL params have highest priority (for testing + sharing)
          if (!theme || !validThemes.includes(theme)) {
            const cookies = parseCookies();
            theme = cookies.theme || theme;
            mode = cookies.mode || mode;
          }
          if (!mode || !validModes.includes(mode)) {
            const cookies = parseCookies();
            mode = cookies.mode || mode;
          }

          if (!theme || !validThemes.includes(theme)) {
            theme = localStorage.getItem('theme');
          }
          if (!mode || !validModes.includes(mode)) {
            mode = localStorage.getItem('mode');
          }

          if (!theme) theme = 'architectural';
          if (!mode) {
            mode = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }

          // Persist chosen values so they survive when URL params are removed
          localStorage.setItem('theme', theme);
          localStorage.setItem('mode', mode);

          document.documentElement.dataset.theme = theme;
          document.documentElement.dataset.mode = mode;

          // Mark that JS is active early — used by any progressive enhancement (reveals, etc.)
          // This runs before body paint so first paint is always fully styled.
          document.documentElement.classList.add('js');
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <slot />

    <!-- ========================================================================
         Single lightweight vanilla scroll-reveal enhancer (replaces 12+ Svelte islands)
         - Zero Svelte hydration cost for motion.
         - First paint is 100% complete, styled, and visible (no opacity-0 white phase).
         - Post-paint (rAF), off-screen .scroll-reveal elements are silently prepped.
         - IntersectionObserver + sibling stagger (65ms, cap 180ms) for premium editorial cadence.
         - Identical visual contract to previous (restrained, expensive feeling).
         - Fully gated by prefers-reduced-motion.
         - Plain JS only (no TS generics in <script> at runtime; @ts-nocheck for astro check).
         ======================================================================== -->
    <script>
      // @ts-nocheck
      (function () {
        'use strict';

        function initScrollReveals() {
          const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (reducedMotion) return;

          const revealEls = Array.from(document.querySelectorAll('.scroll-reveal'));
          if (!revealEls.length) return;

          // 1. Post-paint prep for offscreen elements (prevents any flash on initial visible paint)
          revealEls.forEach((el) => {
            const rect = el.getBoundingClientRect();
            const isInViewport = rect.top < window.innerHeight && rect.bottom > 0;
            if (isInViewport) {
              el.classList.add('in-view');
            } else {
              el.classList.add('reveal-prep');
            }
          });

          // 2. IntersectionObserver with sibling-aware stagger (mirrors prior premium feel exactly)
          const pendingTimeouts = new Set();

          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              const el = /** @type {HTMLElement} */ (entry.target);

              const parent = el.parentElement;
              const siblings = Array.from(parent ? parent.children : []).filter((c) =>
                c.classList.contains('scroll-reveal') &&
                c.classList.contains('reveal-prep') &&
                !c.classList.contains('in-view')
              );
              const idx = siblings.indexOf(el);
              const delay = idx >= 0 ? Math.min(idx * 65, 180) : 0;

              const tid = window.setTimeout(() => {
                pendingTimeouts.delete(tid);
                el.classList.remove('reveal-prep');
                el.classList.add('in-view');
                observer.unobserve(el);
              }, delay);
              pendingTimeouts.add(tid);
            });
          }, {
            threshold: 0.12,
            rootMargin: '0px 0px -40px 0px'
          });

          // Observe only the ones we prepped for reveal
          revealEls.forEach((el) => {
            if (el.classList.contains('reveal-prep')) {
              observer.observe(el);
            }
          });

          // Cleanup on unload (good hygiene)
          window.addEventListener('beforeunload', () => {
            observer.disconnect();
            pendingTimeouts.forEach((tid) => {
              if (typeof tid === 'number') clearTimeout(tid);
            });
            pendingTimeouts.clear();
          }, { once: true });
        }

        // Run after first paint for perfect initial render
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', () => {
            requestAnimationFrame(() => requestAnimationFrame(initScrollReveals));
          });
        } else {
          requestAnimationFrame(() => requestAnimationFrame(initScrollReveals));
        }
      })();
    </script>
  </body>
</html>
