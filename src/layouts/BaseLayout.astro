---
import '../styles/global.css';
import { frontmatter as s } from '../content/settings.md';
const { title = s.name } = Astro.props;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={s.metaDescription || `${s.name} ${s.tagline} in Bülach. Clean cuts, sharp fades und präzise Schnitte.`} />
    <meta name="theme-color" content="#131313" />

    <!-- Open Graph / Social -->
    <meta property="og:title" content={`${s.name} | ${s.tagline} in Bülach`} />
    <meta property="og:description" content={s.ogDescription || 'Präzise Schnitte. Klare Linien. Dein Style. Unser Fokus.'} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://marenacutz.ch" />
    <meta property="og:locale" content="de_CH" />
    <meta property="og:image" content="/images/salon-hero-new.png" />
    <meta property="og:image:alt" content={s.ogImageAlt || `${s.name} barber shop in Bülach`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${s.name} | ${s.tagline}`} />
    <meta name="twitter:description" content={s.twitterDescription || 'Clean Cuts. Sharp Fades. Präzise Schnitte in Bülach.'} />
    <meta name="twitter:image" content="/images/salon-hero-new.png" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Theme initialization (prevents flash) -->
    <script is:inline>
      (function() {
        try {
          const params = new URLSearchParams(window.location.search);
          let theme = params.get('theme');
          let mode = params.get('mode');

          const validThemes = ['architectural', 'brutalist', 'warm', 'cool'];
          const validModes = ['light', 'dark'];

          // URL params have highest priority (for testing + sharing)
          if (!theme || !validThemes.includes(theme)) {
            theme = localStorage.getItem('theme');
          }
          if (!mode || !validModes.includes(mode)) {
            mode = localStorage.getItem('mode');
          }

          if (!theme) theme = 'architectural';
          if (!mode) {
            mode = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }

          // Persist chosen values so they survive when URL params are removed
          localStorage.setItem('theme', theme);
          localStorage.setItem('mode', mode);

          document.documentElement.dataset.theme = theme;
          document.documentElement.dataset.mode = mode;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <slot />
  </body>
</html>
