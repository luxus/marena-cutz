---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { frontmatter as c, compiledContent } from '../content/impressum.md';
const ImpressumContent = await compiledContent();
---
<BaseLayout title={`${c.title} | Marena Cutz`}>
  <Header />
  <main class="min-h-screen border-b border-outline-variant bg-surface px-5 py-20">
    <article class="prose prose-invert mx-auto max-w-3xl prose-headings:uppercase prose-headings:font-display prose-a:text-primary">
      <h1 class="text-headline-lg uppercase">{c.title}</h1>
      <div set:html={ImpressumContent} />
    </article>
  </main>
  <Footer />
</BaseLayout>
