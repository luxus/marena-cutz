---
import { getEntry, render } from 'astro:content';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const [entryImp, settingsEntry] = await Promise.all([
  getEntry('impressum', 'impressum'),
  getEntry('settings', 'settings'),
]);
const c = entryImp!.data;
const s = settingsEntry!.data;
const { Content } = await render(entryImp!);
---

<BaseLayout title={`${c.title} | ${s.name}`}>
  <Header />
  <main id="main" class="min-h-screen border-b border-outline-variant bg-surface px-5 py-20">
    <article class="legal-content mx-auto max-w-3xl">
      <h1 class="text-headline-lg uppercase">{c.title}</h1>

      <h2>{s.name}</h2>
      <p>
        {s.owner}<br />
        {s.address}<br />
        {s.zipCity}<br />
        Schweiz
      </p>
      <p>
        Telefon: <a href={`tel:${s.phone}`}>{s.phone}</a><br />
        E-Mail: <a href={`mailto:${s.email}`}>{s.email}</a>
      </p>

      <Content />
      <p>{s.owner}</p>
    </article>
  </main>
  <Footer />
</BaseLayout>
