---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { frontmatter as c, compiledContent } from '../content/datenschutz.md';
import { frontmatter as s } from '../content/settings.md';
import BaseLayout from '../layouts/BaseLayout.astro';

const bodyHtml = c.body ?? (await compiledContent());
---

<BaseLayout title={`${c.title} | ${s.name}`}>
  <Header />
  <main id="main" class="min-h-screen border-b border-outline-variant bg-surface px-5 py-20">
    <article class="legal-content mx-auto max-w-3xl">
      <h1 class="text-headline-lg uppercase">{c.title}</h1>

      <h2>Kontakt</h2>
      <p>
        {s.name}<br />
        {s.address}<br />
        {s.zipCity}<br />
        Schweiz
      </p>
      <p>E-Mail: <a href={`mailto:${s.email}`}>{s.email}</a></p>

      <div set:html={bodyHtml} />
    </article>
  </main>
  <Footer />
</BaseLayout>
