---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { frontmatter as s } from '../content/settings.md';
import { frontmatter as c, compiledContent } from '../content/datenschutz.md';
const DatenschutzContent = await compiledContent();
---
<BaseLayout title={`${c.title} | ${s.name}`}>
  <Header />
  <main class="min-h-screen border-b border-outline-variant bg-surface px-5 py-20">
    <article class="prose prose-invert mx-auto max-w-3xl prose-headings:uppercase prose-headings:font-display prose-a:text-primary">
      <h1 class="text-headline-lg uppercase">{c.title}</h1>
      
      <h2>Kontakt</h2>
      <p>
        {s.name}<br />
        {s.address}<br />
        {s.zipCity}<br />
        Schweiz
      </p>
      <p>E-Mail: <a href={`mailto:${s.email}`}>{s.email}</a></p>

      <div set:html={DatenschutzContent} />
    </article>
  </main>
  <Footer />
</BaseLayout>
