---
import { getEntry, render } from 'astro:content';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const [entryDs, settingsEntry] = await Promise.all([
  getEntry('datenschutz', 'datenschutz'),
  getEntry('settings', 'settings'),
]);
const c = entryDs!.data;
const s = settingsEntry!.data;
const { Content } = await render(entryDs!);
---

<BaseLayout title={`${c.title} | ${s.name}`}>
  <Header />
  <main id="main" class="min-h-screen border-b border-outline-variant bg-surface px-5 py-20">
    <article class="legal-content mx-auto max-w-3xl">
      <h1 class="text-headline-lg uppercase">{c.title}</h1>

      <h2>Kontakt</h2>
      <p>
        {s.name}<br />
        {s.address}<br />
        {s.zipCity}<br />
        Schweiz
      </p>
      <p>E-Mail: <a href={`mailto:${s.email}`}>{s.email}</a></p>

      <Content />
    </article>
  </main>
  <Footer />
</BaseLayout>
