---
import AboutTeam from '../components/AboutTeam.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Prices from '../components/Prices.astro';
import SocialMedia from '../components/SocialMedia.astro';
import StickyMobileNav from '../components/StickyMobileNav.astro';
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const settingsEntry = await getEntry('settings', 'settings');
const s = settingsEntry!.data;
---

<BaseLayout title={`${s.name} | Barber in Bülach – Haarschnitte & Fades`}
  ><Header /><main id="main"><Hero /><Prices /><AboutTeam /><SocialMedia /></main><Footer
  /><StickyMobileNav /></BaseLayout
>
