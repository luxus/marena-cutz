---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Prices from '../components/Prices.astro';
import AboutTeam from '../components/AboutTeam.astro';
import SocialMedia from '../components/SocialMedia.astro';
import Footer from '../components/Footer.astro';
import StickyMobileNav from '../components/StickyMobileNav.astro';
import { frontmatter as s } from '../content/settings.md';
---
<BaseLayout title={`${s.name} | ${s.tagline} in Bülach`}><Header/><main><Hero/><Prices/><AboutTeam/><SocialMedia/></main><Footer/><StickyMobileNav/></BaseLayout>
