---
import { getEntry } from 'astro:content';
import BookingTrigger from './BookingTrigger.svelte';
import ReceiptIcon from './ReceiptIcon.astro';

const homeEntry = await getEntry('home', 'home');
const c = homeEntry!.data;
---

<section
  class="relative min-h-[700px] lg:min-h-[100vh] overflow-hidden border-b border-outline-variant"
>
  <!-- Full-bleed background using the same pattern as About/Barber sections -->
  <div
    class="absolute inset-0 bg-cover bg-center hero-bg"
    style="background-image: url('/images/salon-hero-new.png')"
  >
  </div>

  <!-- Subtle mouse-following glow -->
  <div class="mouse-glow absolute inset-0 pointer-events-none"></div>

  <div class="absolute inset-0 hero-overlay"></div>
  <!-- Content layer: anchored to the bottom with padding -->
  <div class="relative z-10 min-h-[700px] lg:min-h-[85vh] flex flex-col">
    <!-- Spacer that pushes content to the bottom -->
    <div class="flex-1"></div>

    <div class="mx-auto max-w-7xl px-5 pb-16 md:pb-20">
      <div class="w-full">
        <div class="grid gap-8 md:grid-cols-[2.2fr_0.3fr]">
          <div>
            <p class="hero-text hero-text-1 mb-5 text-label-caps text-secondary">{c.eyebrow}</p>

            <h1
              class="text-display-lg text-[48px] md:text-[102px] md:line-height-[94px] uppercase overflow-hidden"
            >
              <span class="hero-slide hero-slide-left hero-text-2 block">{c.headline}</span>
            </h1>

            <div class="hero-text hero-text-4 my-7 h-px w-full max-w-md bg-secondary"></div>

            <div class="hero-text hero-text-6 mt-8 flex flex-col gap-4 sm:flex-row">
              <!-- Booking button (primary fancy) -->
              <BookingTrigger
                client:load
                label="Termin buchen"
                showIcons={true}
                class="group btn-primary w-full justify-between bg-primary px-8 py-4 sm:w-72 active:scale-[0.982]"
              />

              <!-- Preise button - same structure and effects, secondary colors -->
              <a
                href="#preise"
                class="group btn-secondary w-full justify-between px-8 py-4 sm:w-72 active:scale-[0.982]"
              >
                <ReceiptIcon class="h-4 w-4" />Preise ansehen
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mouse glow script (works for any .mouse-glow in the page) -->
  <script>
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll<HTMLElement>('.mouse-glow').forEach((glow) => {
        const container = glow.closest<HTMLElement>('section') || glow.parentElement;

        if (container) {
          container.addEventListener('mousemove', (e) => {
            const rect = container.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;

            glow.style.setProperty('--mouse-x', `${x}px`);
            glow.style.setProperty('--mouse-y', `${y}px`);
          });
        }
      });
    }
  </script>
</section>
