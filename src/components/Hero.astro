---
import { frontmatter as c } from '../content/home.md';
import { frontmatter as s } from '../content/settings.md';
import ExternalLinkIcon from './ExternalLinkIcon.astro';
---
<section class="relative min-h-[100dvh] overflow-hidden border-b border-outline-variant pt-24"><div class="absolute inset-0"><img src="/images/salon-hero-new.png" alt="Modern interior of Marena Cutz barber shop in Bülach with clean styling stations and premium finishes" class="h-full w-full object-cover opacity-85"/><div class="absolute inset-0 bg-background/80"></div></div>
<div class="relative mx-auto grid min-h-[calc(100dvh-6rem)] max-w-7xl items-center gap-8 px-5 pb-16 md:grid-cols-[2.2fr_0.3fr]">
  <div><p class="mb-5 text-label-caps text-secondary">{c.eyebrow}</p><h1 class="text-display-lg md:text-[102px] md:line-height-[94px] uppercase leading-none tracking-[-0.015em]">
  <span class="block">Clean Cuts.</span>
  <span class="block md:text-[86px] md:line-height-[80px]">Sharp Fades.</span>
</h1><div class="my-7 h-px w-72 bg-secondary"></div><p class="max-w-2xl text-body-lg text-on-surface-variant">{c.text}</p><div class="mt-8 flex flex-col gap-4 sm:flex-row"><a href={s.bookingUrl} target="_blank" rel="noreferrer" class="group inline-flex items-center justify-between bg-primary px-8 py-4 text-label-caps text-on-primary hover:bg-primary-container sm:w-72">Termin buchen <ExternalLinkIcon class="h-4 w-4 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" /></a><a href="#preise" class="inline-flex items-center gap-3 py-4 text-label-caps text-secondary hover:text-secondary-container">Preise ansehen →</a></div></div>
</div></section>
