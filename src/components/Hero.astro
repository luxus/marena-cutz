---
import { frontmatter as c } from '../content/home.md';
import { frontmatter as s } from '../content/settings.md';
---
<section class="relative min-h-screen overflow-hidden border-b border-outline-variant pt-24"><div class="absolute inset-0"><img src="/images/salon-hero-new.png" alt="" class="h-full w-full object-cover opacity-85"/><div class="absolute inset-0 bg-background/80"></div></div>
<div class="relative mx-auto grid min-h-[calc(100vh-6rem)] max-w-7xl items-center gap-8 px-5 pb-16 md:grid-cols-[.9fr_1.1fr]">
  <div><p class="mb-5 text-label-caps text-secondary">{c.eyebrow}</p><h1 class="max-w-xl text-display-lg md:text-[120px] md:line-height-[110px] uppercase">Clean Cuts.<br/>Sharp Fades.</h1><div class="my-7 h-px w-72 bg-secondary"></div><p class="max-w-2xl text-body-lg text-on-surface-variant">{c.text}</p><div class="mt-8 flex flex-col gap-4 sm:flex-row"><a href={s.bookingUrl} target="_blank" rel="noreferrer" class="group inline-flex items-center justify-between bg-primary px-8 py-4 text-label-caps text-on-primary hover:bg-primary-container sm:w-72">Termin buchen <svg viewBox="0 0 24 24" class="h-4 w-4 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7"/><path d="M9 7h8v8"/><path d="M14 17H7V10"/></svg></a><a href="#preise" class="inline-flex items-center gap-3 py-4 text-label-caps text-secondary hover:text-secondary-container">Preise ansehen →</a></div></div>
</div></section>
