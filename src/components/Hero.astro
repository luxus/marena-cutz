---
import { frontmatter as c } from '../content/home.md';
---
<section class="relative min-h-screen overflow-hidden border-b border-white/10 pt-24"><div class="absolute inset-0"><img src="/images/salon-hero-new.png" alt="" class="h-full w-full object-cover opacity-85"/><div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/58 to-black/18"></div><div class="absolute inset-0 bg-[radial-gradient(circle_at_72%_30%,rgba(43,219,205,.16),transparent_34%)]"></div></div>
<div class="relative mx-auto grid min-h-[calc(100vh-6rem)] max-w-7xl items-center gap-8 px-5 pb-16 md:grid-cols-[.9fr_1.1fr]">
  <div><p class="mb-5 text-sm font-bold uppercase tracking-[.22em] text-neon">{c.eyebrow}</p><h1 class="max-w-xl text-6xl font-black uppercase leading-[.9] tracking-[-.06em] md:text-8xl">Clean Cuts.<br/>Sharp Fades.</h1><div class="my-7 h-px w-72 bg-gradient-to-r from-neon via-white/70 to-transparent"></div><p class="max-w-2xl text-lg leading-8 text-white/75 md:text-xl md:leading-9">{c.text}</p><div class="mt-8 flex flex-col gap-4 sm:flex-row"><a href={c.bookingUrl} target="_blank" rel="noreferrer" class="group inline-flex items-center justify-between border border-neon bg-black/50 px-8 py-4 text-sm font-bold uppercase tracking-[.16em] shadow-[0_0_28px_rgba(43,219,205,.16)] hover:bg-neon hover:text-black sm:w-72">Termin buchen <svg viewBox="0 0 24 24" class="h-4 w-4 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7"/><path d="M9 7h8v8"/><path d="M14 17H7V10"/></svg></a><a href="#preise" class="inline-flex items-center gap-3 py-4 text-sm font-bold uppercase tracking-[.16em] text-neon">Preise ansehen →</a></div></div>
  <!-- <div class="relative"><img src="/images/fade-head.svg" alt="Fade Illustration" class="relative mx-auto w-full max-w-[620px] drop-shadow-[0_0_28px_rgba(43,219,205,.20)]"/></div> -->
</div></section>
