---
import { getEntry } from 'astro:content';
import InstagramIcon from './InstagramIcon.astro';
import ThemeSwitcher from './ThemeSwitcher.svelte';
import TikTokIcon from './TikTokIcon.astro';

const settingsEntry = await getEntry('settings', 'settings');
const s = settingsEntry!.data;
---

<footer class="border-t border-outline-variant bg-background px-5 py-10 pb-28 md:pb-10">
  <div class="mx-auto flex max-w-7xl flex-col gap-8 md:flex-row md:items-center md:justify-between">
    <div class="leading-none">
      <a href="/" class="text-title-md uppercase hover:text-primary">{s.name}</a>
      <div class="mt-1 text-label-caps text-on-surface-variant">{s.tagline}</div>
      <div class="mt-3 text-xs text-on-surface-variant opacity-70 space-y-0.5">
        <div>{s.address}</div>
        <div>{s.zipCity}</div>
      </div>
    </div>
    <p class="text-xs tracking-widest text-on-surface-variant uppercase">
      © 2026 {s.name}. Alle Rechte vorbehalten.
    </p>
    <div class="flex items-center gap-4 text-xs tracking-widest text-on-surface-variant">
      <a href="/impressum/" class="nav-link hover:text-primary">Impressum</a>
      <a href="/datenschutz/" class="nav-link hover:text-primary">Datenschutz</a>

      <div class="flex gap-3 pl-3 border-l border-outline-variant text-on-surface-variant">
        <a
          href={s.instagramUrl}
          target="_blank"
          rel="noreferrer"
          aria-label="Instagram"
          class="social-icon-link hover:text-primary"
        >
          <InstagramIcon />
        </a>
        <a
          href={s.tiktokUrl}
          target="_blank"
          rel="noreferrer"
          aria-label="TikTok"
          class="social-icon-link hover:text-primary"
        >
          <TikTokIcon />
        </a>
      </div>

      <!-- Light/dark toggle (architectural theme only) -->
      <div class="pl-3 border-l border-outline-variant">
        <ThemeSwitcher client:load />
      </div>
    </div>
  </div>
</footer>
