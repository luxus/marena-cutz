---
import { frontmatter as s } from '../content/settings.md';
import ThemeSwitcher from './ThemeSwitcher.astro';
---
<footer class="border-t border-outline-variant bg-background px-5 py-10 pb-28 md:pb-10">
  <div class="mx-auto flex max-w-7xl flex-col gap-8 md:flex-row md:items-center md:justify-between">
    <div class="leading-none">
      <a href="/" class="text-title-md uppercase hover:text-primary">{s.name}</a>
      <div class="mt-1 text-label-caps text-on-surface-variant">{s.tagline}</div>
    </div>
    <p class="text-body-lg text-on-surface-variant">© 2026 {s.name}. Alle Rechte vorbehalten.</p>
    <div class="flex items-center gap-4 text-body-lg text-on-surface-variant">
      <a href="/impressum/" class="hover:text-primary">Impressum</a>
      <a href="/datenschutz/" class="hover:text-primary">Datenschutz</a>

      <div class="flex gap-3 pl-3 border-l border-outline-variant text-on-surface-variant">
        <a href={s.instagramUrl} target="_blank" rel="noreferrer" aria-label="Instagram" class="hover:text-primary">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="4" y="4" width="16" height="16" rx="0"/>
            <circle cx="12" cy="12" r="3.5"/>
            <rect x="16" y="6" width="2" height="2" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a href={s.tiktokUrl} target="_blank" rel="noreferrer" aria-label="TikTok" class="hover:text-primary">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
            <path d="M16.2 3c.3 2.3 1.6 3.8 3.8 4v3.2c-1.3.1-2.5-.3-3.7-1.1v5.8c0 3.2-2.1 5.1-5.1 5.1-2.8 0-5.2-1.8-5.2-4.7 0-3.2 2.8-5.1 5.9-4.5v3.2c-1.3-.4-2.6.2-2.6 1.4 0 1 .8 1.6 1.8 1.6 1.2 0 1.9-.7 1.9-2.2V3h3.2Z"/>
          </svg>
        </a>
      </div>

      <!-- Theme Switcher -->
      <div class="pl-3 border-l border-outline-variant">
        <ThemeSwitcher />
      </div>
    </div>
  </div>
</footer>
