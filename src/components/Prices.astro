---
import { frontmatter as prices } from '../content/prices.md';
import { frontmatter as s } from '../content/settings.md';

type Service = { name: string; duration?: string; price: string; featured?: boolean };
type Barber = { name: string; position?: string; image?: string; about?: string; order?: number; services: Service[] };

const barbersFiles = Object.values(import.meta.glob<{ frontmatter: Barber }>('../content/barbers/*.md', { eager: true }));

const barbers = barbersFiles
  .map((file) => file.frontmatter)
  .sort((a: Barber, b: Barber) => (a.order || 0) - (b.order || 0));
---
<section id="preise" class="border-b border-outline-variant bg-surface px-5 py-16 scroll-mt-20">
  <div class="mx-auto grid max-w-7xl items-start gap-10 md:grid-cols-[1fr_2fr]">
    <div>
      <div class="mb-7 flex items-center gap-4">
        <span class="h-px w-8 bg-secondary"></span>
        <h2 class="text-headline-lg uppercase">{prices.title}</h2>
      </div>
      <div class="space-y-5">
        {barbers.map((barber: Barber) => {
          const [primary, ...more] = barber.services;
          return (
            <details class="group">
              <summary class="cursor-pointer list-none marker:hidden [&::-webkit-details-marker]:hidden">
                <div class="flex items-start justify-between gap-5">
                  <div>
                    <h3 class="text-title-md uppercase">{barber.name}</h3>
                    {barber.position && <p class="mt-1 text-label-caps text-secondary">{barber.position}</p>}
                  </div>
                  <span class="grid h-8 w-8 place-items-center text-2xl leading-none text-secondary transition group-open:rotate-45">+</span>
                </div>
                {primary && (
                  <div class="mt-4 grid grid-cols-[1fr_auto] gap-4 border-t border-outline-variant pt-4">
                    <div>
                      <span class="text-body-lg text-on-surface">{primary.name}</span>
                      {primary.duration && <p class="mt-1 text-label-caps text-on-surface-variant">{primary.duration}</p>}
                    </div>
                    <span class="text-label-caps text-secondary">{primary.price}</span>
                  </div>
                )}
                {more.length > 0 && (
                  <div class="mt-3 max-h-11 overflow-hidden text-label-caps text-on-surface-variant [mask-image:linear-gradient(to_bottom,black,transparent)] group-open:hidden">
                    {more.slice(0, 2).map((service: Service) => (
                      <div class="grid grid-cols-[1fr_auto] gap-4 py-1">
                        <span>{service.name}</span>
                        <span>{service.price}</span>
                      </div>
                    ))}
                  </div>
                )}
              </summary>
              {more.length > 0 && (
                <div class="pt-2">
                  {more.map((service: Service) => (
                    <div class="grid grid-cols-[1fr_auto] gap-4 border-t border-outline-variant py-3">
                      <div>
                        <span class:list={["text-body-lg", service.featured ? "text-on-surface" : "text-on-surface-variant"]}>{service.name}</span>
                        {service.duration && <p class="mt-1 text-label-caps text-on-surface-variant">{service.duration}</p>}
                      </div>
                      <span class:list={["text-label-caps", service.featured ? "text-secondary" : "text-on-surface-variant"]}>{service.price}</span>
                    </div>
                  ))}
                </div>
              )}
              <div class="mt-5 h-px bg-outline-variant"></div>
            </details>
          );
        })}
        <a href={s.bookingUrl} target="_blank" rel="noreferrer" class="inline-flex w-full items-center justify-between bg-primary px-6 py-4 text-label-caps text-on-primary hover:bg-primary-container">
          Termin buchen 
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
            <path d="M15 3h6v6"/>
            <path d="M10 14L21 3"/>
          </svg>
        </a>
      </div>
    </div>
    <div id="standort" class="flex flex-col scroll-mt-20">
      <div class="mb-7 flex items-center gap-4">
        <span class="h-px w-8 bg-secondary"></span>
        <h2 class="text-headline-lg uppercase">Standort</h2>
      </div>
      <div class="group relative overflow-hidden border border-outline-variant">
        <a href={s.mapsUrl} target="_blank" rel="noreferrer" aria-label={`Route zu ${s.name} auf Google Maps öffnen`} class="block">
          <img 
            src="/images/location-map.jpg" 
            alt={`Satellitenkarte zum Standort von ${s.name} in Bülach`} 
            class="w-full max-h-[540px] object-cover object-[68%_58%] transition duration-700 group-hover:scale-[1.02] [filter:brightness(0.94)_contrast(1.10)_saturate(0.90)]" 
            loading="lazy" 
          />
          <!-- Dynamic map tint based on theme primary color -->
          <div 
            class="absolute inset-0 mix-blend-[var(--map-tint-blend)] pointer-events-none"
            style="background-color: var(--map-tint-color); opacity: var(--map-tint-opacity);"
          ></div>
          <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
          <div class="absolute bottom-3 left-3 flex items-center gap-2 border border-outline-variant bg-surface/95 px-3 py-1 text-label-caps text-secondary backdrop-blur pointer-events-none transition group-hover:border-secondary">
            <span>📍 {s.address}, {s.zipCity}</span>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
