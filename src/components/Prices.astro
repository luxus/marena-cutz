---
import { frontmatter as prices } from '../content/prices.md';
import { frontmatter as c } from '../content/home.md';

type Service = { name: string; duration?: string; price: string; featured?: boolean };
type Barber = { name: string; label?: string; services: Service[] };
const barbers = prices.barbers as Barber[];
---
<section id="preise" class="border-b border-white/10 bg-bg px-5 py-16"><div class="mx-auto grid max-w-7xl items-start gap-10 md:grid-cols-[.75fr_1.25fr]"><div><div class="mb-7 flex items-center gap-4"><span class="h-px w-8 bg-neon"></span><h2 class="text-4xl font-black uppercase tracking-[-.04em]">{prices.title}</h2></div><div class="space-y-5">{barbers.map((barber) => { const [primary, ...more] = barber.services; return <details class="group"><summary class="cursor-pointer list-none marker:hidden [&::-webkit-details-marker]:hidden"><div class="flex items-start justify-between gap-5"><div><h3 class="text-xl font-black uppercase tracking-[-.04em]">{barber.name}</h3>{barber.label && <p class="mt-1 text-[11px] uppercase tracking-[.18em] text-neon">{barber.label}</p>}</div><span class="grid h-8 w-8 place-items-center text-2xl leading-none text-neon transition group-open:rotate-45">+</span></div>{primary && <div class="mt-4 grid grid-cols-[1fr_auto] gap-4 border-t border-neon/30 pt-4"><div><span class="text-sm uppercase tracking-[.12em] text-white">{primary.name}</span>{primary.duration && <p class="mt-1 text-xs uppercase tracking-[.14em] text-white/40">{primary.duration}</p>}</div><span class="font-bold text-neon">{primary.price}</span></div>}{more.length > 0 && <div class="mt-3 max-h-11 overflow-hidden text-xs uppercase tracking-[.12em] text-white/25 [mask-image:linear-gradient(to_bottom,black,transparent)] group-open:hidden">{more.slice(0, 2).map((service) => <div class="grid grid-cols-[1fr_auto] gap-4 py-1"><span>{service.name}</span><span>{service.price}</span></div>)}</div>}</summary>{more.length > 0 && <div class="pt-2">{more.map((service) => <div class="grid grid-cols-[1fr_auto] gap-4 border-t border-white/10 py-3"><div><span class:list={["text-sm uppercase tracking-[.12em]", service.featured ? "text-white" : "text-white/75"]}>{service.name}</span>{service.duration && <p class="mt-1 text-xs uppercase tracking-[.14em] text-white/40">{service.duration}</p>}</div><span class:list={["font-bold", service.featured ? "text-neon" : "text-white/85"]}>{service.price}</span></div>)}</div>}<div class="mt-5 h-px bg-gradient-to-r from-transparent via-neon/70 to-transparent"></div></details> })}<a href={c.bookingUrl} target="_blank" rel="noreferrer" class="inline-flex w-full items-center justify-between border border-neon/40 px-6 py-4 text-sm font-bold uppercase tracking-[.16em] hover:bg-neon hover:text-black">Termin buchen <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7"/><path d="M9 7h8v8"/><path d="M14 17H7V10"/></svg></a></div></div><div class="relative overflow-hidden"><img src="/images/barber-blueprint-combined.png" alt="Neon Barber Blueprint" class="relative mx-auto max-h-[540px] w-full object-cover drop-shadow-[0_0_34px_rgba(50,230,255,.25)]"/></div></div></section>
