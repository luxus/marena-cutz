---
import { getCollection, getEntry } from 'astro:content';
import BarberPrice from './BarberPrice.svelte';
import BookingDrawer from './BookingDrawer.svelte';
import ParkingDrawer from './ParkingDrawer.svelte';
import ParkingTrigger from './ParkingTrigger.svelte';

const [aboutEntry, bookingEntry, parkingEntry, pricesEntry, settingsEntry, barbersEntries] =
  await Promise.all([
    getEntry('about', 'about'),
    getEntry('booking', 'booking'),
    getEntry('parking', 'parking'),
    getEntry('prices', 'prices'),
    getEntry('settings', 'settings'),
    getCollection('barbers'),
  ]);

const about = aboutEntry!.data;
const booking = bookingEntry!.data;
const parking = parkingEntry!.data;
const prices = pricesEntry!.data;
const s = settingsEntry!.data;

const paymentMethods = about.paymentMethods.filter((m) => m.enabled);

const barbers = barbersEntries
  .map((e) => e.data)
  .filter((b) => b.enabled !== false)
  .sort((a, b) => (a.order || 0) - (b.order || 0));
---

<section class="border-b border-outline-variant bg-surface px-5 py-16">
  <div class="mx-auto grid max-w-7xl items-start gap-10 md:grid-cols-[1fr_2fr]">
    <!-- Prices column: anchor on column (not section) so #preise and #standort align on desktop -->
    <div id="preise" class="scroll-reveal reveal-from-left flex flex-col">
      <div class="mb-7 flex items-center gap-4">
        <span class="h-0.5 w-8 bg-secondary section-accent"></span>
        <h2 class="text-headline-lg uppercase">{prices.title}</h2>
      </div>
      <div>
        {
          barbers.map((barber, index) => (
            <div class={index > 0 ? 'border-t border-outline-variant pt-5' : ''}>
              <BarberPrice client:load {barber} />
            </div>
          ))
        }
        <div class="border-t border-outline-variant pt-5">
        <BookingDrawer
          client:load
          bookingUrl={s.bookingUrl}
          drawerTitle={booking.title}
          paymentNote={booking.paymentNote}
          availabilityTitle={booking.availabilityTitle}
          availabilityText={booking.availabilityText}
          walkInsTitle={booking.walkInsTitle}
          walkInsText={booking.walkInsText}
          cancellationTitle={booking.cancellationTitle}
          cancellationText={booking.cancellationText}
          latenessTitle={booking.latenessTitle}
          latenessText={booking.latenessText}
          ctaLabel={booking.ctaLabel}
          cancelLabel={booking.cancelLabel}
        />
        </div>
        {
          paymentMethods.length > 0 && (
            <div class="pt-2">
              <p class="mb-2 text-label-caps text-on-surface-variant">Akzeptierte Zahlungsmittel</p>
              <div class="flex flex-wrap gap-2">
                {paymentMethods.map((method) => {
                  const key = method.name.toLowerCase();
                  return (
                    <span class="payment-tag border border-secondary px-3 py-1.5 text-label-caps text-secondary flex items-center gap-2">
                      {key === 'twint' && (
                        <svg
                          width="14"
                          height="14"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <polygon points="12,2 20.66,7 20.66,17 12,22 3.34,17 3.34,7" />
                        </svg>
                      )}
                      {key === 'bar' && (
                        <svg
                          width="14"
                          height="14"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="M3 7h14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2z" />
                          <path d="M5 5h14a2 2 0 0 1 2 2" />
                          <path d="M7 3h12a2 2 0 0 1 2 2" />
                          <circle cx="10" cy="13" r="2" />
                          <line x1="14" y1="11" x2="14" y2="11.01" />
                          <line x1="14" y1="15" x2="14" y2="15.01" />
                        </svg>
                      )}
                      {method.name}
                    </span>
                  );
                })}
              </div>
            </div>
          )
        }
      </div>
    </div>

    <!-- Location / map column -->
    <div id="standort" class="scroll-reveal reveal-deep flex flex-col">
      <div class="mb-7 flex items-center gap-4">
        <span class="h-0.5 w-8 bg-secondary section-accent"></span>
        <h2 class="text-headline-lg uppercase">Standort</h2>
      </div>
      <div class="group relative overflow-hidden border border-outline-variant">
        <a
          href={s.mapsUrl}
          target="_blank"
          rel="noreferrer"
          aria-label={`Route zu ${s.name} auf Google Maps öffnen`}
          class="block"
        >
          <img
            src="/images/location-map.jpg"
            alt={`Satellitenkarte zum Standort von ${s.name} in Bülach`}
            class="w-full max-h-[540px] object-cover object-[68%_58%] transition duration-700 group-hover:scale-[1.02] [filter:brightness(0.94)_contrast(1.10)_saturate(0.90)]"
            loading="lazy"
          />
          <!-- Dynamic map tint based on theme primary color -->
          <div
            class="absolute inset-0 mix-blend-[var(--map-tint-blend)] pointer-events-none"
            style="background-color: var(--map-tint-color); opacity: var(--map-tint-opacity);"
          >
          </div>
          <div
            class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"
          >
          </div>
          <div
            class="absolute bottom-3 left-3 flex items-center gap-2 border border-outline-variant bg-surface/95 px-3 py-1 text-label-caps text-secondary backdrop-blur pointer-events-none transition group-hover:border-secondary"
          >
            <span>📍 {s.address}, {s.zipCity}</span>
          </div>
        </a>
      </div>
      <div class="mt-4">
        <ParkingTrigger client:load label={parking.title} />
        <ParkingDrawer
          client:load
          title={parking.title}
          image={parking.image}
          entrance={parking.entrance}
          parking={parking.parking}
          transit={parking.transit}
          mapsUrl={s.mapsUrl}
        />
      </div>
    </div>
  </div>
</section>
