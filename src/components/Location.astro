---
import { frontmatter as c } from '../content/home.md';
---
<section id="standort" class="border-b border-white/10 bg-black px-5 py-20"><div class="mx-auto max-w-7xl"><div class="mb-10 flex items-center gap-4"><span class="h-px w-8 bg-neon"></span><h2 class="text-4xl font-black uppercase tracking-[-.04em]">Standort</h2></div><a href={c.mapsUrl} target="_blank" rel="noreferrer" aria-label="Route zu Marena Cutz auf Google Maps öffnen" class="group relative block min-h-[360px] overflow-hidden border border-white/10 bg-panel shadow-[0_0_45px_rgba(50,230,255,.08)] md:min-h-[560px]"><img src="/images/location-map.png" alt="Stilisierte Karte zum Standort von Marena Cutz in Bülach" class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105" loading="lazy"/><div class="absolute inset-0 bg-[radial-gradient(circle_at_63%_45%,rgba(50,230,255,.18),transparent_28%),linear-gradient(90deg,rgba(0,0,0,.34),transparent_45%),linear-gradient(0deg,rgba(0,0,0,.42),transparent_38%)]"></div><div class="absolute bottom-6 left-6 flex items-center gap-4 border border-neon/40 bg-black/65 px-5 py-4 backdrop-blur transition group-hover:border-neon group-hover:bg-black/80"><img src="/images/google-maps-pin.png" alt="Google Maps" class="h-12 w-10 object-contain" loading="lazy"/><div><p class="text-xs font-bold uppercase tracking-[.2em] text-neon">Marena Cutz</p><p class="mt-1 text-sm text-white/75">{c.address}, {c.zipCity}</p></div></div></a></div></section>
