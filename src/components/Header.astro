---
import { frontmatter as s } from '../content/settings.md';
---
<header class="fixed left-0 top-0 z-50 w-full border-b border-outline-variant bg-surface/55 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4">
    <a href="/" class="leading-none"><div class="text-title-md uppercase">{s.name}</div><div class="mt-1 text-label-caps text-on-surface-variant">{s.tagline}</div></a>
    <nav class="hidden items-center gap-8 text-label-caps text-on-surface-variant md:flex"><a href="#preise" class="hover:text-primary">Preise</a><a href="#standort" class="hover:text-primary">Standort</a><a href="#ueber" class="hover:text-primary">Über</a><div class="flex items-center gap-3"><a href={s.instagramUrl} target="_blank" rel="noreferrer" aria-label="Instagram" class="text-on-surface-variant hover:text-primary"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="4" width="16" height="16" rx="0"/><circle cx="12" cy="12" r="3.5"/><rect x="16" y="6" width="2" height="2" fill="currentColor" stroke="none"/></svg></a><a href={s.tiktokUrl} target="_blank" rel="noreferrer" aria-label="TikTok" class="text-on-surface-variant hover:text-primary"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d="M16.2 3c.3 2.3 1.6 3.8 3.8 4v3.2c-1.3.1-2.5-.3-3.7-1.1v5.8c0 3.2-2.1 5.1-5.1 5.1-2.8 0-5.2-1.8-5.2-4.7 0-3.2 2.8-5.1 5.9-4.5v3.2c-1.3-.4-2.6.2-2.6 1.4 0 1 .8 1.6 1.8 1.6 1.2 0 1.9-.7 1.9-2.2V3h3.2Z"/></svg></a></div><a href={s.bookingUrl} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 bg-primary px-5 py-3 text-on-primary hover:bg-primary-container">Termin buchen <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7"/><path d="M9 7h8v8"/><path d="M14 17H7V10"/></svg></a></nav>
    <div class="flex items-center gap-3 md:hidden"><a href={s.instagramUrl} target="_blank" rel="noreferrer" aria-label="Instagram" class="text-on-surface-variant hover:text-primary"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="4" width="16" height="16" rx="0"/><circle cx="12" cy="12" r="3.5"/><rect x="16" y="6" width="2" height="2" fill="currentColor" stroke="none"/></svg></a><a href={s.tiktokUrl} target="_blank" rel="noreferrer" aria-label="TikTok" class="text-on-surface-variant hover:text-primary"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d="M16.2 3c.3 2.3 1.6 3.8 3.8 4v3.2c-1.3.1-2.5-.3-3.7-1.1v5.8c0 3.2-2.1 5.1-5.1 5.1-2.8 0-5.2-1.8-5.2-4.7 0-3.2 2.8-5.1 5.9-4.5v3.2c-1.3-.4-2.6.2-2.6 1.4 0 1 .8 1.6 1.8 1.6 1.2 0 1.9-.7 1.9-2.2V3h3.2Z"/></svg></a><a href={s.bookingUrl} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 border border-secondary text-secondary px-4 py-2 text-label-caps hover:bg-secondary hover:text-on-secondary">Termin <svg viewBox="0 0 24 24" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7"/><path d="M9 7h8v8"/><path d="M14 17H7V10"/></svg></a></div>
  </div>
</header>
