---
import { getEntry } from 'astro:content';
import BookingTrigger from './BookingTrigger.svelte';
import InstagramIcon from './InstagramIcon.astro';
import Logo from './Logo.astro';
import TikTokIcon from './TikTokIcon.astro';

const settingsEntry = await getEntry('settings', 'settings');
const s = settingsEntry!.data;
---

<header
  id="site-header"
  class="fixed left-0 top-0 z-50 w-full border-b border-transparent transition-colors duration-300 header-transparent"
>
  <div
    class="mx-auto flex max-w-7xl items-center justify-between gap-2 py-3 pl-3 pr-4 md:gap-4 md:px-5 md:py-4"
  >
    <a
      href="/"
      class="inline-flex shrink-0 focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary"
    >
      <Logo alt={`${s.name} – ${s.tagline}`} class="site-logo" priority />
    </a>
    <nav class="hidden items-center gap-8 text-label-caps text-on-surface-variant md:flex">
      <a href="#preise" class="nav-link hover:text-primary">Preise</a><a
        href="#standort"
        class="nav-link hover:text-primary">Standort</a
      ><a href="#ueber" class="nav-link hover:text-primary">Über uns</a><a
        href="#barbers"
        class="nav-link hover:text-primary">Barbers</a
      ><BookingTrigger
        client:load
        label="Termin buchen"
        showIcons={false}
        class="btn-primary px-4 py-2 text-label-caps"
      /><div class="flex items-center gap-3">
        <a
          href="#social"
          aria-label="Instagram"
          class="social-icon-link text-on-surface-variant hover:text-primary"><InstagramIcon /></a
        ><a
          href="#social"
          aria-label="TikTok"
          class="social-icon-link text-on-surface-variant hover:text-primary"><TikTokIcon /></a
        >
      </div>
    </nav>
    <div class="flex shrink-0 items-center gap-3 md:hidden">
      <a
        href="#social"
        aria-label="Instagram"
        class="social-icon-link text-on-surface-variant hover:text-primary"
      >
        <InstagramIcon />
      </a>
      <a
        href="#social"
        aria-label="TikTok"
        class="social-icon-link text-on-surface-variant hover:text-primary"
      >
        <TikTokIcon />
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const update = () => {
      if (window.scrollY > 40) {
        header.classList.remove('header-transparent');
        header.classList.add('header-solid');
      } else {
        header.classList.add('header-transparent');
        header.classList.remove('header-solid');
      }
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
