---
import { frontmatter as c } from '../content/home.md';
---
<header class="fixed left-0 top-0 z-50 w-full border-b border-white/10 bg-black/55 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4">
    <a href="#" class="leading-none"><div class="text-lg font-semibold uppercase tracking-[.18em]">Marena Cutz</div><div class="mt-1 text-[10px] uppercase tracking-[.45em] text-white/55">Modern Barber</div></a>
    <nav class="hidden items-center gap-8 text-xs font-bold uppercase tracking-[.18em] text-white/75 md:flex"><a href="#preise" class="hover:text-neon">Preise</a><a href="#standort" class="hover:text-neon">Standort</a><a href="#ueber" class="hover:text-neon">Über</a><div class="flex items-center gap-3"><a href="#instagram" aria-label="Instagram Vorschau" class="text-white/70 hover:text-neon"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="4" width="16" height="16" rx="5"/><circle cx="12" cy="12" r="3.5"/><circle cx="17" cy="7" r=".8" fill="currentColor" stroke="none"/></svg></a><a href="#tiktok" aria-label="TikTok Vorschau" class="text-white/70 hover:text-neon"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d="M16.2 3c.3 2.3 1.6 3.8 3.8 4v3.2c-1.3.1-2.5-.3-3.7-1.1v5.8c0 3.2-2.1 5.1-5.1 5.1-2.8 0-5.2-1.8-5.2-4.7 0-3.2 2.8-5.1 5.9-4.5v3.2c-1.3-.4-2.6.2-2.6 1.4 0 1 .8 1.6 1.8 1.6 1.2 0 1.9-.7 1.9-2.2V3h3.2Z"/></svg></a></div><a href={c.bookingUrl} class="border border-neon/80 px-5 py-3 text-white shadow-[0_0_22px_rgba(50,230,255,.15)] hover:bg-neon hover:text-black">Termin buchen</a></nav>
    <div class="flex items-center gap-3 md:hidden"><a href="#instagram" aria-label="Instagram Vorschau" class="text-white/75 hover:text-neon"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="4" width="16" height="16" rx="5"/><circle cx="12" cy="12" r="3.5"/><circle cx="17" cy="7" r=".8" fill="currentColor" stroke="none"/></svg></a><a href="#tiktok" aria-label="TikTok Vorschau" class="text-white/75 hover:text-neon"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d="M16.2 3c.3 2.3 1.6 3.8 3.8 4v3.2c-1.3.1-2.5-.3-3.7-1.1v5.8c0 3.2-2.1 5.1-5.1 5.1-2.8 0-5.2-1.8-5.2-4.7 0-3.2 2.8-5.1 5.9-4.5v3.2c-1.3-.4-2.6.2-2.6 1.4 0 1 .8 1.6 1.8 1.6 1.2 0 1.9-.7 1.9-2.2V3h3.2Z"/></svg></a><a href={c.bookingUrl} class="border border-neon px-4 py-2 text-xs font-bold uppercase tracking-[.16em]">Termin</a></div>
  </div>
</header>
