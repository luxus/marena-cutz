---
import { frontmatter as c } from '../content/about.md';
---
<section id="ueber" class="border-b border-white/10 bg-bg px-5 py-20"><div class="mx-auto grid max-w-7xl gap-12 md:grid-cols-[.8fr_1.2fr]"><div><div class="mb-8 flex items-center gap-4"><span class="h-px w-8 bg-neon"></span><h2 class="text-4xl font-black uppercase tracking-[-.04em]">{c.title}</h2></div><p class="max-w-lg text-lg leading-8 text-white/70">{c.text}</p><div class="mt-8 space-y-3 border border-white/10 bg-white/[.025] p-6 text-sm uppercase tracking-[.14em] text-white/70"><p><span class="text-neon">Inhaber:</span> {c.owner}</p><p><span class="text-neon">Telefon:</span> <a href={`tel:${c.phone}`} class="hover:text-neon">{c.phone}</a></p><p><span class="text-neon">E-Mail:</span> <a href={`mailto:${c.email}`} class="break-all hover:text-neon">{c.email}</a></p></div></div><div class="overflow-hidden border border-white/10"><img src="/images/about-salon-hero.png" alt="Marena Cutz Salon" class="h-full min-h-[360px] w-full object-cover opacity-90"/></div></div></section>
