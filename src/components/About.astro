---
import { frontmatter as c } from '../content/about.md';

type OpeningHour = { day: string; hours: string };
const openingHours = (c.openingHours ?? []) as OpeningHour[];
const paymentMethods = (c.paymentMethods ?? []) as string[];
---
<section id="ueber" class="border-b border-white/10 bg-bg px-5 py-20"><div class="mx-auto grid max-w-7xl gap-12 md:grid-cols-[.8fr_1.2fr]"><div><div class="mb-8 flex items-center gap-4"><span class="h-px w-8 bg-neon"></span><h2 class="text-4xl font-black uppercase tracking-[-.04em]">{c.title}</h2></div><p class="max-w-lg text-lg leading-8 text-white/70">{c.text}</p><div class="mt-8 space-y-8 text-sm uppercase tracking-[.14em] text-white/70"><div class="space-y-3"><p><span class="text-neon">Inhaber:</span> {c.owner}</p><p><span class="text-neon">Telefon:</span> <a href={`tel:${c.phone}`} class="hover:text-neon">{c.phone}</a></p><p><span class="text-neon">E-Mail:</span> <a href={`mailto:${c.email}`} class="break-all hover:text-neon">{c.email}</a></p></div><div class="h-px bg-gradient-to-r from-transparent via-neon/70 to-transparent"></div><div><h3 class="mb-4 text-sm font-bold uppercase tracking-[.18em] text-neon">Öffnungszeiten</h3><div class="space-y-3">{openingHours.map((item) => <div class="flex items-center justify-between gap-6 border-b border-neon/15 pb-3 last:border-0 last:pb-0"><span>{item.day}</span><span class:list={["font-bold", item.hours.toLowerCase().includes('geschlossen') ? "text-white/40" : "text-white"]}>{item.hours}</span></div>)}</div></div><div class="h-px bg-gradient-to-r from-transparent via-neon/70 to-transparent"></div><div><h3 class="mb-4 text-sm font-bold uppercase tracking-[.18em] text-neon">Zahlung</h3><div class="flex flex-wrap gap-3">{paymentMethods.map((method) => <span class="bg-neon/10 px-4 py-3 text-sm font-bold uppercase tracking-[.16em] text-white/85 shadow-[inset_0_-1px_0_rgba(50,230,255,.45)]">{method}</span>)}</div></div></div></div><div class="overflow-hidden border border-white/10"><img src="/images/about-salon-hero.png" alt="Marena Cutz Salon" class="h-full min-h-[360px] w-full object-cover opacity-90"/></div></div></section>
