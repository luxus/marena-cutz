---
import { frontmatter as c } from '../content/about.md';
import { frontmatter as s } from '../content/settings.md';

type OpeningHour = { day: string; hours: string };
const openingHours = (c.openingHours ?? []) as OpeningHour[];
const paymentMethods = (c.paymentMethods ?? []) as string[];
---
<section id="ueber" class="border-b border-outline-variant bg-surface px-5 py-20"><div class="mx-auto grid max-w-7xl gap-12 md:grid-cols-[.8fr_1.2fr]"><div><div class="mb-8 flex items-center gap-4"><span class="h-px w-8 bg-secondary"></span><h2 class="text-headline-lg uppercase">{c.title}</h2></div><p class="max-w-lg text-body-lg text-on-surface-variant">{c.text}</p><div class="mt-8 space-y-8 text-label-caps text-on-surface-variant"><div class="space-y-3"><p><span class="text-secondary">Inhaber:</span> {s.owner}</p><p><span class="text-secondary">Telefon:</span> <a href={`tel:${s.phone}`} class="hover:text-primary">{s.phone}</a></p><p><span class="text-secondary">E-Mail:</span> <a href={`mailto:${s.email}`} class="break-all hover:text-primary">{s.email}</a></p></div><div class="h-px bg-outline-variant"></div><div><h3 class="mb-4 text-label-caps text-secondary">Öffnungszeiten</h3><div class="space-y-3">{openingHours.map((item) => <div class="flex items-center justify-between gap-6 border-b border-outline-variant pb-3 last:border-0 last:pb-0"><span>{item.day}</span><span class:list={["font-bold", item.hours.toLowerCase().includes('geschlossen') ? "text-on-surface-variant" : "text-on-surface"]}>{item.hours}</span></div>)}</div></div><div class="h-px bg-outline-variant"></div><div><h3 class="mb-4 text-label-caps text-secondary">Zahlung</h3><div class="flex flex-wrap gap-3">{paymentMethods.map((method) => <span class="border border-secondary px-4 py-3 text-label-caps text-secondary">{method}</span>)}</div></div></div></div><div class="relative overflow-hidden border border-outline-variant"><img src="/images/about-salon-hero.png" alt={`${s.name} Salon`} class="h-full min-h-[360px] w-full object-cover opacity-85 saturate-[.85]"/></div></div></section>
