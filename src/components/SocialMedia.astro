---
import { frontmatter as s } from '../content/settings.md';

const items = [
  { platform: 'Instagram', imageUrl: '/images/instagram-dxbxnz7jefd-browser.jpg', alt: 'Clean Fade', permalink: s.instagramUrl },
  { platform: 'TikTok', imageUrl: '/images/tiktok-7573325880508927254.jpg', alt: 'Styling', permalink: s.tiktokUrl, featured: true },
  { platform: 'Instagram', imageUrl: '/images/instagram-dw8lhwxjfjo-browser.jpg', alt: 'Transformation', permalink: s.instagramUrl },
  { platform: 'TikTok', imageUrl: '/images/tiktok-7627810109564931350.jpg', alt: 'Beard Trim', permalink: s.tiktokUrl },
  { platform: 'Instagram', imageUrl: '/images/instagram-dxsuwndbmf-browser.jpg', alt: 'Precision Work', permalink: s.instagramUrl },
  { platform: 'TikTok', imageUrl: '/images/tiktok-7559314663998278934.jpg', alt: 'Barber Detail', permalink: s.tiktokUrl }
];
---
<section id="social" class="bg-background px-5 py-20 pb-32 md:pb-20 scroll-mt-20">
  <div class="mx-auto grid max-w-7xl gap-12 md:grid-cols-[.8fr_1.2fr]">
    <div>
      <div class="mb-8 flex items-center gap-4">
        <span class="h-px w-8 bg-secondary"></span>
        <h2 class="text-headline-lg uppercase">Social Media</h2>
      </div>
      <p class="max-w-sm text-body-lg text-on-surface-variant">Ausgewählte Cuts, Transformationen und Barber-Momente aus Instagram und TikTok.</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={s.instagramUrl} target="_blank" rel="noreferrer" class="inline-flex items-center gap-4 bg-surface px-6 py-4 text-label-caps text-on-surface hover:bg-surface-container hover:text-secondary">
          Instagram <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><path d="M15 3h6v6"/><path d="M10 14L21 3"/></svg>
        </a>
        <a href={s.tiktokUrl} target="_blank" rel="noreferrer" class="inline-flex items-center gap-4 bg-surface px-6 py-4 text-label-caps text-on-surface hover:bg-surface-container hover:text-secondary">
          TikTok <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><path d="M15 3h6v6"/><path d="M10 14L21 3"/></svg>
        </a>
      </div>
    </div>
    <div class="grid max-w-2xl grid-cols-2 gap-4 md:justify-self-end lg:grid-cols-3">
      {items.map((item) => (
        <a href={item.permalink} target="_blank" rel="noreferrer" class:list={["group relative overflow-hidden border bg-surface", item.featured ? "border-primary" : "border-outline-variant"]}>
          <img src={item.imageUrl} alt={item.alt} class="aspect-square w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" />
          <span class="absolute left-3 top-3 bg-surface/80 px-3 py-1 text-label-caps text-on-surface backdrop-blur">{item.platform}</span>
        </a>
      ))}
    </div>
  </div>
</section>
