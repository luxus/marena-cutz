---
import { frontmatter as home } from '../content/home.md';
import { frontmatter as s } from '../content/settings.md';
import SocialCarousel from './SocialCarousel.svelte';

const items = (home.socialItems ?? []) as {
  platform: string;
  imageUrl: string;
  permalink: string;
  alt: string;
  objectPosition?: string;
  featured?: boolean;
}[];
---

<section id="social" class="bg-background py-20 pb-32 md:pb-20 scroll-mt-20">
  <div class="mx-auto max-w-7xl px-5">
    <!-- Left column: intro + links -->
    <div class="scroll-reveal">
      <div class="mb-8 flex items-center gap-4">
        <span class="h-0.5 w-8 bg-secondary section-accent"></span>
        <h2 class="text-headline-lg uppercase">Social Media</h2>
      </div>
      <p class="max-w-sm text-body-lg text-on-surface-variant">
        Ausgewählte Cuts, Transformationen und Barber-Momente aus Instagram und TikTok.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={s.instagramUrl}
          target="_blank"
          rel="noreferrer"
          class="nav-link inline-flex items-center gap-2 text-label-caps text-on-surface-variant hover:text-primary"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="4"
            ></circle><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"
            ></circle></svg
          >
          Instagram
        </a>
        <a
          href={s.tiktokUrl}
          target="_blank"
          rel="noreferrer"
          class="nav-link inline-flex items-center gap-2 text-label-caps text-on-surface-variant hover:text-primary"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
            ><path
              d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"
            ></path></svg
          >
          TikTok
        </a>
      </div>
    </div>
  </div>

  <!-- Auto-scroll carousel -->
  <div class="mt-10 px-5">
    <SocialCarousel client:visible {items} />
  </div>
</section>
