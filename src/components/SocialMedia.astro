---
import { getEntry } from 'astro:content';
import InstagramIcon from './InstagramIcon.astro';
import SocialCarousel from './SocialCarousel.svelte';
import TikTokIcon from './TikTokIcon.astro';

const [homeEntry, settingsEntry] = await Promise.all([
  getEntry('home', 'home'),
  getEntry('settings', 'settings'),
]);
const home = homeEntry!.data;
const s = settingsEntry!.data;

const items = home.socialItems;
---

<section id="social" class="bg-background py-20 pb-32 md:pb-20">
  <div class="mx-auto max-w-7xl px-5">
    <!-- Left column: intro + links -->
    <div class="scroll-reveal">
      <div class="mb-8 flex items-center gap-4">
        <span class="h-0.5 w-8 bg-secondary section-accent"></span>
        <h2 class="text-headline-lg uppercase">Social Media</h2>
      </div>
      <p class="max-w-sm text-body-lg text-on-surface-variant">
        Ausgewählte Cuts, Transformationen und Barber-Momente aus Instagram und TikTok.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={s.instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="nav-link inline-flex items-center gap-2 text-label-caps text-on-surface-variant hover:text-primary"
        >
          <InstagramIcon class="h-3.5 w-3.5" />
          Instagram
        </a>
        <a
          href={s.tiktokUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="nav-link inline-flex items-center gap-2 text-label-caps text-on-surface-variant hover:text-primary"
        >
          <TikTokIcon class="h-3.5 w-3.5" />
          TikTok
        </a>
      </div>
    </div>
  </div>

  <!-- Auto-scroll carousel — right-edge fade signals more content beyond -->
  <div class="mt-10 px-5 relative">
    <div class="social-carousel-fade-mask">
      <SocialCarousel client:visible {items} />
    </div>
  </div>
</section>
