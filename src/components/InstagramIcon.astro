---
interface Props {
  class?: string;
  /** When set, icon is exposed as an image with this accessible name. Otherwise decorative. */
  'aria-label'?: string;
}

const { class: className = 'h-5 w-5', 'aria-label': ariaLabel } = Astro.props;
const decorative = !ariaLabel;
---

<svg
  viewBox="0 0 24 24"
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  role={decorative ? undefined : 'img'}
  aria-label={ariaLabel}
  aria-hidden={decorative ? 'true' : undefined}
>
  <rect x="4" y="4" width="16" height="16" rx="0"></rect>
  <circle cx="12" cy="12" r="3.5"></circle>
  <rect x="16" y="6" width="2" height="2" fill="currentColor" stroke="none"></rect>
</svg>
