---
interface Props {
  class?: string;
  'aria-label'?: string;
}

const { class: className = 'h-5 w-5', 'aria-label': ariaLabel = 'Instagram' } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  aria-label={ariaLabel}
  role="img"
>
  <rect x="4" y="4" width="16" height="16" rx="0" />
  <circle cx="12" cy="12" r="3.5" />
  <rect x="16" y="6" width="2" height="2" fill="currentColor" stroke="none" />
</svg>